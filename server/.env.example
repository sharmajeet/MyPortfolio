# Copy to .env and fill in real values
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# Comma-separated origins allowed to call the API (your frontend)
CORS_ORIGIN=http://localhost:5173

# Number of proxy hops to trust for the real client IP (1 on most hosts)
TRUST_PROXY=1

# Auth — use a long random string for the secret
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=604800

# Admin account, seeded on first startup if it doesn't exist
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-min-8-chars

# Resume served after the lead-capture form (path relative to the server folder)
RESUME_PATH=../public/Jeet_Sharma_Resume.pdf

# Optional: when set, the API also serves the built frontend from this folder
# (used by the Docker single-image deploy; leave empty in local dev).
# WEB_DIR=./public-web
