# Frontend environment (Vite). Copy to .env for local overrides.

# Production API origin, e.g. https://api.yourdomain.com
# Leave empty in dev — requests go to /api and are forwarded by the proxy below.
VITE_API_URL=

# Dev only: where `npm run dev` forwards /api requests.
VITE_DEV_API_PROXY=http://localhost:4000
